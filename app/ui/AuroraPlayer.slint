import { QueueView } from "QueueView.slint";
import { ContextMenu, PlContextMenu, QueueContextMenu } from "CustomComp.slint";
import { TabSelectorView } from "TabSelectorView.slint";
import { MainView } from "MainView.slint";
import { NowPlayingView } from "NowPlayingView.slint";
import { PlayerView } from "PlayerView.slint";
import {
    CurrentSong,
    Song,
    Tabs,
    Theme,
    PlaylistMinimal,
    Playlist,
} from "Types.slint";
import "../assets/NotoSans.ttf";
import "../assets/JetbrainsMono.ttf";

export { Theme }

export component AuroraPlayer inherits Window {
    callback queue-click(int);
    callback queue-remove(int);
    callback queue-clear();
    callback queue-move(int, int);
    callback prev();
    callback pause();
    callback next();
    callback seek(float);
    callback search(string, string, bool);
    callback add(string);
    callback enqueue(string);
    callback play-next(string);
    callback refresh-playlists();
    callback select-playlist(string);
    callback replace-queue(Playlist);
    callback show-context-menu(string, bool, length, length);
    callback create-playlist(string);
    callback add-songs-to-playlist(string, string);
    callback remove-song-from-playlist(string, string);
    callback delete-playlist(string);
    callback rename-playlist(string, string);
    callback toggle-song-selection(string);
    callback set-shuffle(bool);
    callback set-repeat(int);
    callback set-volume(float);
    callback get-artist-list();
    callback get-songs-by-artist(string);
    callback get-last-played();
    callback clear-song-selection();
    callback like-song(string);
    callback unlike-song(string);
    callback get-liked-songs();

    in-out property <string> Title: "Nothing Playing";
    in-out property <string> Artists: "No artist";
    in-out property <image> AlbumArt: @image-url("../assets/placeholder.png");
    in-out property <int> position: 0;
    in-out property <bool> is_paused: true;
    in-out property <int> duration: 0;

    in-out property <bool> shuffle: false;
    in-out property <int> repeat-mode: 0;
    in-out property <float> volume: 1.0;
    in-out property <[string]> artist-list;
    in-out property <[Song]> artist-songs;
    in-out property <bool> has-art: false;
    in-out property <[Song]> last-played: [];
    in-out property <[Song]> liked-songs;
    in-out property <string> current-playing-id: "";
    in-out property <bool> current-song-liked: false;

    in-out property <[Song]> queue;
    in-out property <[Song]> searchResults;
    in-out property <[PlaylistMinimal]> playlistsList;
    in-out property <Playlist> playlistResult: {
        title: "Playlist Test",
        id:"id",
        songs: [
            { album-art:  @image-url("../assets/placeholder.png"), title: "Song", artists: "Artist", duration: "" }
        ]
    };

    in-out property <Tabs> active-view: Tabs.Library;
    in-out property <bool> disconnected: false;

    in-out property <bool> context-menu-visible: false;
    in-out property <length> context-menu-x: 0px;
    in-out property <length> context-menu-y: 0px;
    in-out property <string> context-menu-song-id: "";
    in-out property <bool> context-menu-song-liked: false;

    in-out property <bool> pl-context-menu-visible: false;
    in-out property <length> pl-context-menu-x: 0px;
    in-out property <length> pl-context-menu-y: 0px;
    in-out property <string> pl-context-menu-playlist-id: "";
    in-out property <string> pl-context-menu-playlist-title: "";

    in-out property <bool> queue-ctx-visible: false;
    in-out property <length> queue-ctx-x: 0px;
    in-out property <length> queue-ctx-y: 0px;
    in-out property <int> queue-ctx-idx: -1;

    forward-focus: key-handler;

    title: "Aurora Player";
    min-height: 650px;
    min-width: 1155px;
    preferred-height: 800px;
    preferred-width: 1422px;
    default-font-family: "Noto Sans JP";

    pl-context-menu := PlContextMenu {
        menu-visible <=> root.pl-context-menu-visible;
        x-position <=> root.pl-context-menu-x;
        y-position <=> root.pl-context-menu-y;
        playlist-id <=> root.pl-context-menu-playlist-id;
        playlist-title <=> root.pl-context-menu-playlist-title;
        delete-playlist(id) => { root.delete-playlist(id); }
        rename-playlist(id, title) => {
            main-view.renaming-playlist-id = id;
            main-view.new-playlist-name = title;
        }
    }

    context-menu := ContextMenu {
        menu-visible <=> root.context-menu-visible;
        x-position <=> root.context-menu-x;
        y-position <=> root.context-menu-y;
        song-id <=> root.context-menu-song-id;
        song-liked <=> root.context-menu-song-liked;
        window-height: root.height;
        playlists: root.playlistsList;
        playlist-id: main-view.in-playlist ? root.playlistResult.id : "";
        play-next(id) => { root.play-next(id); }
        add-to-queue(id) => { root.enqueue(id); }
        like-song(id) => { root.like-song(id); }
        unlike-song(id) => { root.unlike-song(id); }
        add-to-playlist(playlist-id) => {
            root.add-songs-to-playlist(playlist-id, root.context-menu-song-id);
        }
        remove-song-from-playlist(song-id) => {
            root.remove-song-from-playlist(root.playlistResult.id, song-id);
        }
    }

    queue-ctx-menu := QueueContextMenu {
        menu-visible <=> root.queue-ctx-visible;
        x-position <=> root.queue-ctx-x;
        y-position <=> root.queue-ctx-y;
        queue-idx <=> root.queue-ctx-idx;
        move-to-front(idx) => { root.queue-move(idx, 0); }
        remove-from-queue(idx) => { root.queue-remove(idx + 1); }
    }

    key-handler := FocusScope {
        key-pressed(event) => {
            if event.modifiers.control && event.text == Key.Escape {
                root.clear-song-selection();
                return EventResult.accept;
            }
            EventResult.reject
        }

        Rectangle {
            background: Theme.bgd0;
        HorizontalLayout {
            spacing: 5px;
            padding: 5px;
            VerticalLayout {
                spacing: 5px;

                QueueView {
                    queue: root.queue;
                    queue-click(n) => { root.queue-click(n) }
                    queue-remove(n) => { root.queue-remove(n) }
                    queue-clear => { root.queue-clear() }
                    queue-move(from, to) => { root.queue-move(from, to) }
                    show-queue-context-menu(idx, x, y) => {
                        root.queue-ctx-idx = idx;
                        root.queue-ctx-x = (x + 160px > root.width) ? max(0px, x - 160px) : x;
                        root.queue-ctx-y = (y + 90px > root.height) ? max(0px, y - 90px) : y;
                        root.queue-ctx-visible = true;
                    }
                }

                VerticalLayout {
                    NowPlayingView {
                        Title: root.Title;
                        Artists: root.Artists;
                        AlbumArt: root.AlbumArt;
                        has-art: root.has-art;
                        width: 400px;
                        height: 100px;
                    }
                }
            }

            VerticalLayout {
                spacing: 5px;

                TabSelectorView {
                    active-view <=> root.active-view;
                    refresh-library => {
                        root.get-liked-songs();
                        root.refresh-playlists();
                    }
                }

                main-view := MainView {
                    active-view: root.active-view;
                    searchResults: root.searchResults;
                    current-playlist: root.playlistResult;
                    playlists: root.playlistsList;
                    liked-songs: root.liked-songs;
                    last-played: root.last-played;
                    current-song-id: root.current-playing-id;
                    query-submit(q, m, f) => { search(q, m, f); }
                    add(s) => { root.add(s); }
                    get-playlist(s) => { select-playlist(s) }
                    replace-queue(pl) => { root.replace-queue(pl) }
                    show-context-menu(id, liked, x, y) => {
                        root.context-menu-song-id = id;
                        root.context-menu-song-liked = liked;
                        root.context-menu-x = (x + 200px > root.width) ? max(0px, x - 200px) : x;
                        root.context-menu-y = y;
                        root.context-menu-visible = true;
                    }
                    show-playlist-context-menu(id, title, x, y) => {
                        root.pl-context-menu-playlist-id = id;
                        root.pl-context-menu-playlist-title = title;
                        root.pl-context-menu-x = (x + 200px > root.width) ? max(0px, x - 200px) : x;
                        root.pl-context-menu-y = (y + 90px > root.height) ? max(0px, y - 90px) : y;
                        root.pl-context-menu-visible = true;
                    }
                    create-playlist(name) => { root.create-playlist(name); }
                    rename-playlist(id, name) => { root.rename-playlist(id, name); }
                    toggle-song-selection(id) => { root.toggle-song-selection(id); }
                    toggle-liked(id, liked) => {
                        if (liked) { root.unlike-song(id); } else { root.like-song(id); }
                    }
                }

                PlayerView {
                    pause => { root.pause() }
                    next => { root.next() }
                    prev => { root.prev() }
                    seek(value) => { seek(value); }
                    set-shuffle(b) => { root.set-shuffle(b); }
                    set-repeat(r) => { root.set-repeat(r); }
                    set-volume(v) => { root.set-volume(v); }
                    like-toggle => {
                        if (root.current-song-liked) {
                            root.unlike-song(root.current-playing-id);
                        } else {
                            root.like-song(root.current-playing-id);
                        }
                    }
                    value <=> position;
                    duration: root.duration;
                    is-paused: root.is_paused;
                    shuffle <=> root.shuffle;
                    repeat <=> root.repeat-mode;
                    volume <=> root.volume;
                    is-liked: root.current-song-liked;
                }
            }
        }
        dismiss-area := TouchArea {
            width: 100%;
            height: 100%;
            enabled: root.context-menu-visible || root.pl-context-menu-visible || root.queue-ctx-visible;
            clicked => {
                if root.context-menu-visible {
                    if (self.mouse-x < context-menu.x || self.mouse-x > context-menu.x + 200px ||
                        self.mouse-y < context-menu.y || self.mouse-y > context-menu.y + context-menu.height) {
                        root.context-menu-visible = false;
                    }
                }
                if root.pl-context-menu-visible {
                    if (self.mouse-x < root.pl-context-menu-x || self.mouse-x > root.pl-context-menu-x + 200px ||
                        self.mouse-y < root.pl-context-menu-y || self.mouse-y > root.pl-context-menu-y + 90px) {
                        root.pl-context-menu-visible = false;
                    }
                }
                if root.queue-ctx-visible {
                    if (self.mouse-x < root.queue-ctx-x || self.mouse-x > root.queue-ctx-x + 160px ||
                        self.mouse-y < root.queue-ctx-y || self.mouse-y > root.queue-ctx-y + 90px) {
                        root.queue-ctx-visible = false;
                    }
                }
            }
        }
    }

    if root.disconnected: Rectangle {
        z: 2000;
        background: #000000cc;

        Rectangle {
            width: 420px;
            height: 160px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.bgd1;
            border-radius: 15px;
            border-width: 1px;
            border-color: Theme.bgd4;
            drop-shadow-color: Theme.bgd0;
            drop-shadow-blur: 20px;

            VerticalLayout {
                padding: 30px;
                spacing: 12px;
                alignment: center;

                Text {
                    text: "Disconnected from daemon";
                    color: Theme.txt1;
                    font-size: 20px;
                    horizontal-alignment: center;
                }

                Text {
                    text: "The Aurora daemon has stopped. Close the player.";
                    color: Theme.txt2;
                    font-size: 14px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
    }
}
}
