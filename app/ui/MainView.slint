import { VerticalBox, HorizontalBox } from "std-widgets.slint";
import { ComboBox, SongList } from "CustomComp.slint";
import { Song, PlaylistMinimal, Playlist, Theme, Tabs } from "Types.slint";
import { LibraryView } from "LibraryView.slint";

export component SearchView inherits VerticalBox {
    in-out property <string> searchMode: "By Title";
    in-out property <string> query: "";
    in property <[Song]> searchResults;
    in property <string> current-song-id: "";
    callback submit(string, string, bool);
    callback item-clicked(string);
    callback show-context-menu(string, bool, length, length);
    callback toggle-song-selection(string);
    callback toggle-liked(string, bool);
    padding: 5px;

    VerticalLayout {
        spacing: 5px;

        HorizontalLayout {
            spacing: 5px;
            Rectangle {
                border-radius: 10px;
                height: 60px;
                background: Theme.bgd1;
                border-width: 1px;
                HorizontalBox {
                    padding: 10px;

                    Text {
                        text: "\u{f002}";
                        height: parent.height - 20px;
                        width: parent.height - 20px;
                        font-size: 30px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        color: Theme.srch;
                        font-family: "JetBrainsMono NFP";
                    }

                    Rectangle {
                        clip: true;
                        TextInput {
                            font-size: 30px;
                            vertical-alignment: center;
                            color: Theme.txt1;
                            text <=> query;
                            changed text => {
                                submit(query, searchMode, false);
                            }
                            accepted => {
                                submit(query, searchMode, true)
                            }
                        }
                    }
                }
            }

            ComboBox {
                height: 60px;
                width: 160px;
                model: ["By Artist", "By Title"];
                current <=> searchMode;
                changed current => {
                    submit(query, searchMode, false);
                }
            }
        }

        if query == "" && searchResults.length == 0: VerticalLayout {
            alignment: center;

            VerticalLayout {
                spacing: 15px;

                Text {
                    text: "\u{f002}";
                    font-family: "JetBrainsMono NFP";
                    font-size: 90px;
                    color: Theme.bgd3;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Search your library";
                    color: Theme.txt2;
                    font-size: 24px;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Find songs by title or artist using the bar above";
                    color: Theme.srch;
                    font-size: 15px;
                    horizontal-alignment: center;
                }
            }
        }

        if !(query == "" && searchResults.length == 0): SongList {
            z: -1;
            items: searchResults;
            current-song-id: current-song-id;
            item-clicked(id) => { item-clicked(id); }
            show-context-menu(id, liked, x, y) => { show-context-menu(id, liked, x, y); }
            toggle-selection(id) => { toggle-song-selection(id); }
            toggle-liked(id, liked) => { toggle-liked(id, liked); }
        }
    }
}

export component MainView inherits Rectangle {
    background: Theme.bgd2;
    border-radius: 15px;
    in property <Tabs> active-view;
    in property <[Song]> searchResults;
    in property <[PlaylistMinimal]> playlists;
    in property <Playlist> current-playlist;
    in property <[Song]> liked-songs;
    in property <string> current-song-id: "";
    out property <bool> in-playlist <=> libView.in-playlist;
    in-out property <string> renaming-playlist-id <=> libView.renaming-playlist-id;
    in-out property <string> new-playlist-name <=> libView.new-playlist-name;
    callback query-submit(string, string, bool);
    callback add(string);
    callback get-playlist(string);
    callback replace-queue(Playlist);
    callback show-context-menu(string, bool, length, length);
    callback show-playlist-context-menu(string, string, length, length);
    callback create-playlist(string);
    callback rename-playlist(string, string);
    callback toggle-song-selection(string);
    callback toggle-liked(string, bool);

    SearchView {
        states [
            visible when active-view == Tabs.Search: {
                opacity: 1;
                visible: true;
                in-out { animate opacity { duration: 100ms; } }
            }
            invisible when active-view != Tabs.Search: {
                opacity: 0;
                visible: false;
                in-out { animate opacity { duration: 100ms; } }
            }
        ]

        searchResults: root.searchResults;
        current-song-id: root.current-song-id;
        submit(q, m, f) => { query-submit(q, m, f); }
        item-clicked(id) => { add(id); }
        show-context-menu(id, liked, x, y) => { show-context-menu(id, liked, x, y); }
        toggle-song-selection(id) => { toggle-song-selection(id); }
        toggle-liked(id, liked) => { toggle-liked(id, liked); }
    }

    libView := LibraryView {
        states [
            visible when active-view == Tabs.Library: {
                opacity: 1;
                visible: true;
                in-out { animate opacity { duration: 100ms; } }
            }
            invisible when active-view != Tabs.Library: {
                opacity: 0;
                visible: false;
                in-out { animate opacity { duration: 100ms; } }
            }
        ]
        liked-songs: root.liked-songs;
        playlists: root.playlists;
        current-playlist: root.current-playlist;
        current-song-id: root.current-song-id;
        item-clicked(id) => { root.add(id); }
        show-context-menu(id, liked, x, y) => { root.show-context-menu(id, liked, x, y); }
        toggle-song-selection(id) => { root.toggle-song-selection(id); }
        toggle-liked(id, liked) => { root.toggle-liked(id, liked); }
        show-playlist-context-menu(id, title, x, y) => { root.show-playlist-context-menu(id, title, x, y); }
        get-playlist(id) => { root.get-playlist(id); }
        replace-queue(pl) => { root.replace-queue(pl); }
        create-playlist(name) => { root.create-playlist(name); }
        rename-playlist(id, name) => { root.rename-playlist(id, name); }
    }
}
