import { HorizontalBox, VerticalBox } from "std-widgets.slint";
import { Song, PlaylistMinimal, Theme } from "Types.slint";

export component ScrollView inherits Rectangle {
    in property <int> direction: 1;
    out property <length> viewport-y <=> touch.viewport-y;
    private property <length> content-height: layout.preferred-height;

    min-width: 0px;
    min-height: 0px;
    clip: true;

    changed content-height => {
        touch.viewport-y = 0
    }

    touch := TouchArea {
        width: parent.width;
        height: parent.height;

        property <length> viewport-y;
        scroll-event(event) => {
            viewport-y = min(0px, max(-(content-height - parent.height), viewport-y - (root.direction * event.delta-y)));
            return accept;
        }

        rect := Rectangle {
            y: touch.viewport-y;
            width: parent.width;
            height: layout.preferred-height;
            layout := VerticalLayout {
                @children
            }
        }
    }
}

export component CustomSlider inherits Rectangle {

    in property <bool> enabled: true;
    in property <int> minimum: 0;
    in property <int> maximum: 100;

    in-out property <int> value: 0;
    in-out property <int> displayValue: value;
    in-out property <int> displayHoverValue: 0;

    in property <int> step: 10000;
    callback released(float);

    private property <float> normalizedDisplayValue: (displayValue - minimum) / (maximum - minimum);
    private property <float> normalizedDisplayHoverValue: (displayHoverValue - minimum) / (maximum - minimum);
    private property <float> normalizedValue: (value - minimum) / (maximum - minimum);
    private property <bool> pressed: false;

    changed value => {
        if !root.pressed {
            root.displayValue = root.value;
        }
    }

    height: 40px;
    track := Rectangle {
        y: (parent.height - self.height) / 2;
        height: touch.has-hover ? 12px : 6px;
        background: Theme.bgd3;
        border-radius: touch.has-hover ? 6px : 3px;

        animate height, border-radius { duration: 100ms; }

        fillHover := HorizontalBox {
            alignment: LayoutAlignment.start;
            padding: 0px;
            width: track.width;
            visible: touch.has-hover;

            Rectangle {
                width: track.width * root.normalizedDisplayHoverValue;
                background: Theme.bgd4;
                border-radius: track.border-radius;
            }
        }

        fill := HorizontalBox {
            alignment: LayoutAlignment.start;
            padding: 0px;
            width: track.width;

            Rectangle {
                width: track.width * root.normalizedDisplayValue;
                background: Theme.acct;
                border-radius: track.border-radius;
            }
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        height: self.has-hover ? 12px : 6px;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.pressed = true;
                root.displayValue = root.minimum + (root.maximum - root.minimum) * clamp(self.mouse-x / root.width, 0, 1);
                root.displayHoverValue = root.displayValue;
            }
            if (event.kind == PointerEventKind.move) {
                if (root.pressed) {
                    root.displayValue = root.minimum + (root.maximum - root.minimum) * clamp(self.mouse-x / root.width, 0, 1);
                    root.displayHoverValue = root.displayValue;
                } else if (self.has-hover) {
                    root.displayHoverValue = root.minimum + (root.maximum - root.minimum) * clamp(self.mouse-x / root.width, 0, 1);
                }
            }
            if (event.kind == PointerEventKind.up) {
                root.pressed = false;
                root.released(root.displayValue);
            }
        }
    }

    
}

export component ComboBox {
    in-out property <[string]> model;
    in-out property <string> current;
    private property <bool> expanded: false;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.bgd2;
        border-radius: 10px;
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.expanded = !root.expanded;
                if root.expanded {
                    box.height = model.length * 50px + 15px;
                } else {
                    box.height = 0;
                }
            }
        }

        HorizontalLayout {
            padding: 10px;
            Text {
                text: root.current;
                vertical-alignment: center;
                font-size: 20px;
                color: Theme.txt1;
            }

            Text {
                text: root.expanded ? "\u{25B2}" : "\u{25BC}";
                horizontal-alignment: right;
                vertical-alignment: center;
                color: Theme.txt1;
            }
        }
    }

    box := Rectangle {
        background: Theme.bgd2;
        border-width: 2px;
        border-color: Theme.acct;
        y: parent.height + 5px;
        height: 0px;
        border-radius: 10px;
        clip: true;
        animate height {
            duration: 100ms;
            easing: ease-in-out-quad;
        }
        drop-shadow-color: Theme.bgd0;
        drop-shadow-blur: 10px;
        TouchArea { }

        VerticalLayout {
            spacing: 5px;
            padding: 5px;
            width: parent.width;
            for item[i] in model: Rectangle {
                width: parent.width - 10px;
                border-radius: 5px;
                height: 50px;

                background: item == root.current ? Theme.bgd3 : Theme.bgd2;
                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => {
                        root.current = item;
                        root.expanded = false;
                        box.height = 0;
                    }
                }

                HorizontalBox {
                    padding: 10px;
                    Text {
                        text: item;
                        vertical-alignment: center;
                        font-size: 15px;
                        color: Theme.txt1;
                    }
                }
            }
        }
    }
}

export component SongCard inherits Rectangle {
    in property <Song> song;
    in property <bool> current: false;
    callback clicked();

    width: 150px;
    height: 204px;
    border-radius: 10px;
    background: touch.has-hover ? Theme.bgd3 : Theme.bgd2;
    animate background { duration: 100ms; }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        Rectangle {
            height: 122px;
            border-radius: 8px;
            clip: true;
            Image {
                source: root.song.album-art;
                width: parent.width;
                height: parent.height;
            }
        }

        Text {
            text: root.song.title;
            color: root.current ? Theme.acct : Theme.txt1;
            font-size: 16px;
            overflow: elide;
            horizontal-alignment: left;
        }

        Text {
            text: root.song.artists;
            color: Theme.txt2;
            font-size: 13px;
            overflow: elide;
            horizontal-alignment: left;
        }
    }
}

export component SongCardRow inherits Rectangle {
    in property <[Song]> items;
    in property <string> current-song-id: "";
    callback item-clicked(string);

    height: 204px;
    clip: true;

    ScrollView {
        direction: 1;
        HorizontalLayout {
            spacing: 10px;
            padding: 0px;
            for item[i] in items: SongCard {
                song: item;
                current: root.current-song-id != "" && item.id == root.current-song-id;
                clicked => {
                    root.item-clicked(item.id);
                }
            }
        }
    }
}

export component PlaylistCard inherits Rectangle {
    in property <PlaylistMinimal> playlist;
    in property <string> icon: "";
    callback clicked();
    callback show-context-menu(string, string, length, length);

    width: 170px;
    height: 224px;
    border-radius: 10px;
    background: touch.has-hover ? Theme.bgd3 : Theme.bgd2;
    animate background { duration: 100ms; }

    touch := TouchArea {
        pointer-event(event) => {
            if event.button == PointerEventButton.right && event.kind == PointerEventKind.down {
                show-context-menu(playlist.id, playlist.title, touch.absolute-position.x + touch.mouse-x, touch.absolute-position.y + touch.mouse-y);
            }
        }
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        Rectangle {
            height: 138px;
            border-radius: 8px;
            background: Theme.bgd3;
            clip: true;

            if root.icon != "": Text {
                text: root.icon;
                font-family: "JetBrainsMono NFP";
                font-size: 64px;
                color: Theme.acct;
                width: parent.width;
                height: parent.height;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            if root.icon == "": GridLayout {
                spacing: 0px;
                Row {
                    Rectangle {
                        width: 69px; height: 69px; background: Theme.bgd3; clip: true;
                        if playlist.album-arts.length > 0: Image { source: playlist.album-arts[0]; width: parent.width; height: parent.height; image-fit: cover; }
                        if playlist.album-arts.length == 0: Text { text: "\u{f0025}"; font-family: "JetBrainsMono NFP"; font-size: 38px; color: Theme.txt2; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Rectangle {
                        width: 69px; height: 69px; background: Theme.bgd3; clip: true;
                        if playlist.album-arts.length > 1: Image { source: playlist.album-arts[1]; width: parent.width; height: parent.height; image-fit: cover; }
                        if playlist.album-arts.length <= 1: Text { text: "\u{f0025}"; font-family: "JetBrainsMono NFP"; font-size: 38px; color: Theme.txt2; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                Row {
                    Rectangle {
                        width: 69px; height: 69px; background: Theme.bgd3; clip: true;
                        if playlist.album-arts.length > 2: Image { source: playlist.album-arts[2]; width: parent.width; height: parent.height; image-fit: cover; }
                        if playlist.album-arts.length <= 2: Text { text: "\u{f0025}"; font-family: "JetBrainsMono NFP"; font-size: 38px; color: Theme.txt2; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Rectangle {
                        width: 69px; height: 69px; background: Theme.bgd3; clip: true;
                        if playlist.album-arts.length > 3: Image { source: playlist.album-arts[3]; width: parent.width; height: parent.height; image-fit: cover; }
                        if playlist.album-arts.length <= 3: Text { text: "\u{f0025}"; font-family: "JetBrainsMono NFP"; font-size: 38px; color: Theme.txt2; width: parent.width; height: parent.height; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }

        Text {
            text: playlist.title;
            color: Theme.txt1;
            font-size: 18px;
            overflow: elide;
            horizontal-alignment: left;
        }

        Text {
            text: playlist.length + (playlist.length == 1 ? " song" : " songs");
            color: Theme.txt2;
            font-size: 14px;
            overflow: elide;
            horizontal-alignment: left;
        }
    }
}

export component PlList inherits VerticalLayout {
    in property <[PlaylistMinimal]> items;
    in property <int> liked-count: 0;
    callback item-clicked(string);
    callback show-context-menu(string, string, length, length);
    callback liked-clicked();

    private property <int> total: 1 + items.length;
    private property <int> columns: 1;
    private property <int> row-count: (total + columns - 1) / columns;

    init => { columns = max(1, floor(self.width / 184px)); }
    changed width => { columns = max(1, floor(self.width / 184px)); }

    Rectangle {
        border-radius: 10px;
        clip: true;
        ScrollView {
            direction: -1;
            VerticalLayout {
                spacing: 14px;
                padding: 0px;

                for row in row-count: HorizontalLayout {
                    spacing: 14px;
                    padding: 0px;
                    alignment: start;

                    for col in columns: PlaylistCard {
                        private property <bool> is-liked: (row * columns + col) == 0;
                        private property <int> pl-idx: max(0, (row * columns + col) - 1);
                        visible: (row * columns + col) < total;
                        icon: is-liked ? "\u{f004}" : "";
                        playlist: is-liked
                            ? { title: "Liked Songs", id: "__liked__", length: liked-count }
                            : items[pl-idx];
                        clicked => {
                            if (is-liked) { root.liked-clicked(); }
                            else { root.item-clicked(items[pl-idx].id); }
                        }
                        show-context-menu(id, title, x, y) => {
                            if (!is-liked) { root.show-context-menu(id, title, x, y); }
                        }
                    }
                }
            }
        }
    }
}

export component SongList inherits VerticalLayout {
    in property <[Song]> items;
    in property <string> current-song-id: "";
    callback item-clicked(string);
    callback show-context-menu(string, bool, length, length);
    callback toggle-selection(string);
    callback toggle-liked(string, bool);
    Rectangle {
        border-radius: 10px;
        clip: true;
        ScrollView {
            direction: -1;
            box := VerticalBox {
                spacing: 5px;
                padding: 0px;
                for item[i] in items: Rectangle {
                    private property <bool> ctrl-pressed: false;
                    border-radius: 10px;
                    background: item.selected ? Theme.bgd4 : (touch.has-hover ? Theme.bgd3 : Theme.bgd2);
                    animate background { duration: 100ms; }

                    Rectangle {
                        x: 0px;
                        y: 4px;
                        width: 4px;
                        height: parent.height - 8px;
                        background: Theme.acct;
                        border-radius: 2px;
                        visible: item.selected;
                    }

                    Rectangle {
                        x: item.selected ? 6px : 0px;
                        y: 4px;
                        width: 3px;
                        height: parent.height - 8px;
                        background: Theme.acct;
                        border-radius: 2px;
                        opacity: 0.6;
                        visible: root.current-song-id != "" && item.id == root.current-song-id && !item.selected;
                    }

                    touch := TouchArea {
                        pointer-event(event) => {
                            if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                                ctrl-pressed = event.modifiers.control;
                            }
                            if event.button == PointerEventButton.right && event.kind == PointerEventKind.down {
                                show-context-menu(item.id, item.liked, touch.absolute-position.x + touch.mouse-x, touch.absolute-position.y + touch.mouse-y);
                            }
                        }
                        clicked => {
                            if ctrl-pressed {
                                toggle-selection(item.id);
                            } else {
                                item-clicked(item.id);
                            }
                            ctrl-pressed = false;
                        }
                    }

                    HorizontalLayout {
                        padding: 5px;
                        padding-left: item.selected ? 12px : 5px;
                        padding-right: 10px;
                        spacing: 10px;

                        Rectangle {
                            height: 50px;
                            width: 50px;
                            border-radius: 10px;
                            background: Theme.bgd3;
                            clip: true;
                            if item.has_art: Image {
                                source: item.album_art;
                                height: parent.width;
                                width: parent.height;
                            }
                            if !item.has_art: Text {
                                text: "\u{f0025}";
                                font-family: "JetBrainsMono NFP";
                                font-size: 26px;
                                color: Theme.txt2;
                                width: parent.width;
                                height: parent.height;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            alignment: LayoutAlignment.center;
                            spacing: 2px;
                            Text {
                                text: item.title;
                                color: root.current-song-id != "" && item.id == root.current-song-id ? Theme.acct : Theme.txt1;
                                font-size: 20px;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                overflow: elide;
                            }
                            Text {
                                text: item.artists;
                                color: Theme.txt2;
                                font-size: 15px;
                                vertical-alignment: center;
                                horizontal-alignment: left;
                                overflow: elide;
                            }
                        }

                        Rectangle {
                            width: 24px;
                            heart-ta := TouchArea {
                                clicked => { root.toggle-liked(item.id, item.liked); }
                            }
                            Text {
                                text: item.liked ? "\u{f004}" : (touch.has-hover || heart-ta.has-hover ? "\u{eb05}" : "");
                                color: Theme.acct;
                                font-size: 18px;
                                font-family: "JetBrainsMono NFP";
                                vertical-alignment: center;
                                horizontal-alignment: center;
                                width: parent.width;
                            }
                        }

                        Text {
                            text: item.duration;
                            color: Theme.txt2;
                            font-size: 14px;
                            vertical-alignment: center;
                            horizontal-alignment: right;
                            width: 55px;
                        }
                    }
                }
            }
        }
    }
}

export component ArtistList inherits VerticalLayout {
    in property <[string]> items;
    callback item-clicked(string);
    Rectangle {
        border-radius: 10px;
        clip: true;
        ScrollView {
            direction: -1;
            box := VerticalBox {
                spacing: 5px;
                padding: 0px;
                for item[i] in items: Rectangle {
                    height: 60px;
                    border-radius: 10px;
                    background: touch.has-hover ? Theme.bgd3 : Theme.bgd2;
                    animate background { duration: 100ms; }

                    touch := TouchArea {
                        clicked => {
                            item-clicked(item);
                        }
                    }

                    HorizontalLayout {
                        padding: 15px;
                        Text {
                            text: item;
                            color: Theme.txt1;
                            font-size: 25px;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }
                    }
                }
            }
        }
    }
}

export component MenuItem inherits Rectangle {
    in property <string> text;
    in property <length> item-font-size: 16px;
    callback clicked;
    in-out property <bool> enabled: true;

    height: 40px;
    border-radius: 5px;
    background: touch.has-hover && root.enabled ? Theme.bgd3 : Theme.bgd2;
    opacity: root.enabled ? 1.0 : 0.5;
    animate background { duration: 100ms; }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        enabled: root.enabled;
        clicked => {
            if root.enabled { root.clicked(); }
        }
    }

    HorizontalLayout {
        padding: 10px;
        Text {
            text: root.text;
            color: Theme.txt1;
            font-size: root.item-font-size;
            vertical-alignment: center;
            horizontal-alignment: left;
        }
    }
}

component ContextMenuBase inherits Rectangle {
    in-out property <bool> menu-visible: false;
    in property <length> x-position: 0px;
    in property <length> y-position: 0px;

    width: 200px;
    background: Theme.bgd2;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.bgd4;
    drop-shadow-color: Theme.bgd0;
    drop-shadow-blur: 10px;
    z: 1000;
    x: root.x-position;
    y: root.y-position;
    visible: root.menu-visible;
}

export component PlContextMenu inherits ContextMenuBase {
    in property <string> playlist-id;
    in property <string> playlist-title;
    callback rename-playlist(string, string);
    callback delete-playlist(string);

    height: 90px;

    VerticalLayout {
        padding: 5px;
        MenuItem {
            text: "Rename";
            width: 100%;
            clicked => { root.rename-playlist(root.playlist-id, root.playlist-title); root.menu-visible = false; }
        }
        MenuItem {
            text: "Delete Playlist";
            width: 100%;
            clicked => { root.delete-playlist(root.playlist-id); root.menu-visible = false; }
        }
    }
}

export component QueueContextMenu inherits ContextMenuBase {
    in-out property <int> queue-idx: -1;
    callback move-to-front(int);
    callback remove-from-queue(int);

    width: 160px;
    height: 90px;

    VerticalLayout {
        padding: 5px;
        MenuItem {
            text: "Move to Front";
            width: 100%;
            clicked => { root.move-to-front(root.queue-idx); root.menu-visible = false; }
        }
        MenuItem {
            text: "Remove";
            width: 100%;
            clicked => { root.remove-from-queue(root.queue-idx); root.menu-visible = false; }
        }
    }
}

export component ContextMenu inherits ContextMenuBase {
    in property <string> song-id;
    in property <[PlaylistMinimal]> playlists;
    in property <string> playlist-id: "";
    in property <length> window-height: 0px;
    in property <bool> song-liked: false;

    private property <bool> show-playlist-submenu: false;
    private property <length> expansion-height: show-playlist-submenu ? playlists.length * 40px : 0px;
    // Expand submenu upward when there isn't enough room below
    private property <bool> submenu-expand-up:
        root.y-position + 170px + (root.playlist-id != "" ? 40px : 0px) + root.playlists.length * 40px > root.window-height;
    animate expansion-height { duration: 150ms; easing: ease-in-out-quad; }

    out property <length> total-height:
        170px +
        (playlist-id != "" ? 40px : 0px) +
        (show-playlist-submenu ? playlists.length * 40px : 0px);

    callback add-to-queue(string);
    callback play-next(string);
    callback like-song(string);
    callback unlike-song(string);
    callback add-to-playlist(string);
    callback remove-song-from-playlist(string);

    height: root.total-height;
    y: submenu-expand-up ? max(0px, root.y-position - expansion-height) : root.y-position;
    clip: true;
    animate height { duration: 150ms; easing: ease-in-out-quad; }

    changed menu-visible => {
        if !root.menu-visible {
            show-playlist-submenu = false;
        }
    }

    VerticalLayout {
        spacing: 0px;
        padding: 5px;
        width: 100%;

        MenuItem {
            text: "Play Next";
            width: 100%;
            clicked => { root.play-next(root.song-id); root.menu-visible = false; }
        }
        MenuItem {
            text: "Add to Queue";
            width: 100%;
            clicked => { root.add-to-queue(root.song-id); root.menu-visible = false; }
        }
        MenuItem {
            text: root.song-liked ? "Remove from Liked Songs" : "Add to Liked Songs";
            width: 100%;
            clicked => {
                if (root.song-liked) {
                    root.unlike-song(root.song-id);
                } else {
                    root.like-song(root.song-id);
                }
                root.menu-visible = false;
            }
        }

        if submenu-expand-up: Rectangle {
            width: parent.width - 10px;
            height: show-playlist-submenu ? playlists.length * 40px : 0px;
            clip: true;
            animate height { duration: 150ms; easing: ease-in-out-quad; }
            VerticalLayout {
                spacing: 2px;
                padding: 0px;
                for pl in playlists: MenuItem {
                    text: pl.title;
                    item-font-size: 14px;
                    height: 38px;
                    width: parent.width;
                    clicked => { root.add-to-playlist(pl.id); root.menu-visible = false; }
                }
            }
        }

        MenuItem {
            text: show-playlist-submenu ? "Add to Playlist \u{25B2}" : "Add to Playlist \u{25BC}";
            width: 100%;
            clicked => { show-playlist-submenu = !show-playlist-submenu; }
        }

        if !submenu-expand-up: Rectangle {
            width: parent.width - 10px;
            height: show-playlist-submenu ? playlists.length * 40px : 0px;
            clip: true;
            animate height { duration: 150ms; easing: ease-in-out-quad; }
            VerticalLayout {
                spacing: 2px;
                padding: 0px;
                for pl in playlists: MenuItem {
                    text: pl.title;
                    item-font-size: 14px;
                    height: 38px;
                    width: parent.width;
                    clicked => { root.add-to-playlist(pl.id); root.menu-visible = false; }
                }
            }
        }

        Rectangle {
            width: parent.width;
            height: playlist-id != "" ? 40px : 0px;
            clip: true;
            animate height { duration: 150ms; easing: ease-in-out-quad; }
            MenuItem {
                text: "Remove from Playlist";
                width: 100%;
                clicked => { root.remove-song-from-playlist(root.song-id); root.menu-visible = false; }
            }
        }
    }
}
